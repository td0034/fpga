# 25 MHz oscillator
LOCATE COMP "clk" SITE "G2";
IOBUF PORT "clk" IO_TYPE=LVCMOS33;
FREQUENCY PORT "clk" 25 MHZ;

# PCM1808 ADC on GP0–GP3, GP7–GP9
LOCATE COMP "adc_sck" SITE "B11";   # GP0 — 12.5 MHz system clock
LOCATE COMP "adc_lrc" SITE "A10";   # GP1 — I2S word select
LOCATE COMP "adc_out" SITE "A9";    # GP2 — I2S data input
LOCATE COMP "adc_bck" SITE "B9";    # GP3 — I2S bit clock
LOCATE COMP "adc_mdo" SITE "A6";    # GP7 — mode 1 (slave)
LOCATE COMP "adc_mdi" SITE "A4";    # GP8 — mode 0 (slave)
LOCATE COMP "adc_fmy" SITE "A2";    # GP9 — format (I2S)
IOBUF PORT "adc_sck" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "adc_lrc" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "adc_out" PULLMODE=NONE IO_TYPE=LVCMOS33;
IOBUF PORT "adc_bck" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "adc_mdo" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "adc_mdi" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "adc_fmy" IO_TYPE=LVCMOS33 DRIVE=4;

# PCM5102A DAC on GN0–GN7
LOCATE COMP "dac_flt" SITE "C11";   # GN0 — filter select
LOCATE COMP "dac_dmp" SITE "A11";   # GN1 — de-emphasis
LOCATE COMP "dac_scl" SITE "B10";   # GN2 — system clock
LOCATE COMP "dac_bck" SITE "C10";   # GN3 — I2S bit clock
LOCATE COMP "dac_din" SITE "A8";    # GN4 — I2S serial data
LOCATE COMP "dac_lck" SITE "B8";    # GN5 — I2S word select
LOCATE COMP "dac_fmt" SITE "C7";    # GN6 — format select
LOCATE COMP "dac_xmt" SITE "B6";    # GN7 — mute control
IOBUF PORT "dac_flt" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "dac_dmp" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "dac_scl" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "dac_bck" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "dac_din" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "dac_lck" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "dac_fmt" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "dac_xmt" IO_TYPE=LVCMOS33 DRIVE=4;

# LEDs (active high)
LOCATE COMP "led[0]" SITE "B2";
LOCATE COMP "led[1]" SITE "C2";
LOCATE COMP "led[2]" SITE "C1";
LOCATE COMP "led[3]" SITE "D2";
LOCATE COMP "led[4]" SITE "D1";
LOCATE COMP "led[5]" SITE "E2";
LOCATE COMP "led[6]" SITE "E1";
LOCATE COMP "led[7]" SITE "H3";
IOBUF PORT "led[0]" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "led[1]" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "led[2]" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "led[3]" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "led[4]" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "led[5]" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "led[6]" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "led[7]" IO_TYPE=LVCMOS33 DRIVE=4;
