# ULX3S v2.0 Pin Constraints (ECP5 LFE5U-85F, CABGA381)
# Reference: https://github.com/emard/ulx3s/blob/master/doc/constraints/ulx3s_v20.lpf

# 25 MHz oscillator
LOCATE COMP "clk" SITE "G2";
IOBUF PORT "clk" PULLMODE=NONE IO_TYPE=LVCMOS33;
FREQUENCY PORT "clk" 25 MHZ;

# 8 LEDs (active high, LVCMOS33, 4mA drive)
LOCATE COMP "led[0]" SITE "B2";
LOCATE COMP "led[1]" SITE "C2";
LOCATE COMP "led[2]" SITE "C1";
LOCATE COMP "led[3]" SITE "D2";
LOCATE COMP "led[4]" SITE "D1";
LOCATE COMP "led[5]" SITE "E2";
LOCATE COMP "led[6]" SITE "E1";
LOCATE COMP "led[7]" SITE "H3";
IOBUF PORT "led[0]" PULLMODE=NONE IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "led[1]" PULLMODE=NONE IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "led[2]" PULLMODE=NONE IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "led[3]" PULLMODE=NONE IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "led[4]" PULLMODE=NONE IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "led[5]" PULLMODE=NONE IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "led[6]" PULLMODE=NONE IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "led[7]" PULLMODE=NONE IO_TYPE=LVCMOS33 DRIVE=4;

# Buttons
LOCATE COMP "btn_pwr" SITE "D6";
LOCATE COMP "btn_fire1" SITE "R1";
LOCATE COMP "btn_fire2" SITE "T1";
LOCATE COMP "btn_up" SITE "R18";
LOCATE COMP "btn_down" SITE "V1";
LOCATE COMP "btn_left" SITE "U1";
LOCATE COMP "btn_right" SITE "H16";
IOBUF PORT "btn_pwr" PULLMODE=DOWN IO_TYPE=LVCMOS33;
IOBUF PORT "btn_fire1" PULLMODE=DOWN IO_TYPE=LVCMOS33;
IOBUF PORT "btn_fire2" PULLMODE=DOWN IO_TYPE=LVCMOS33;
IOBUF PORT "btn_up" PULLMODE=DOWN IO_TYPE=LVCMOS33;
IOBUF PORT "btn_down" PULLMODE=DOWN IO_TYPE=LVCMOS33;
IOBUF PORT "btn_left" PULLMODE=DOWN IO_TYPE=LVCMOS33;
IOBUF PORT "btn_right" PULLMODE=DOWN IO_TYPE=LVCMOS33;

# UART (active via FTDI bridge)
LOCATE COMP "ftdi_rxd" SITE "M1";
LOCATE COMP "ftdi_txd" SITE "L4";
IOBUF PORT "ftdi_rxd" PULLMODE=NONE IO_TYPE=LVCMOS33;
IOBUF PORT "ftdi_txd" PULLMODE=NONE IO_TYPE=LVCMOS33;

# WiFi GPIO (active — pull high so ESP32 active boots normally)
LOCATE COMP "wifi_gpio0" SITE "L2";
IOBUF PORT "wifi_gpio0" PULLMODE=UP IO_TYPE=LVCMOS33;

# Audio jack (4-bit resistor DAC per channel, 3.5mm output)
LOCATE COMP "audio_l[0]" SITE "E4";
LOCATE COMP "audio_l[1]" SITE "D3";
LOCATE COMP "audio_l[2]" SITE "C3";
LOCATE COMP "audio_l[3]" SITE "B3";
LOCATE COMP "audio_r[0]" SITE "A3";
LOCATE COMP "audio_r[1]" SITE "B5";
LOCATE COMP "audio_r[2]" SITE "D5";
LOCATE COMP "audio_r[3]" SITE "C5";
IOBUF PORT "audio_l[0]" PULLMODE=NONE IO_TYPE=LVCMOS33;
IOBUF PORT "audio_l[1]" PULLMODE=NONE IO_TYPE=LVCMOS33;
IOBUF PORT "audio_l[2]" PULLMODE=NONE IO_TYPE=LVCMOS33;
IOBUF PORT "audio_l[3]" PULLMODE=NONE IO_TYPE=LVCMOS33;
IOBUF PORT "audio_r[0]" PULLMODE=NONE IO_TYPE=LVCMOS33;
IOBUF PORT "audio_r[1]" PULLMODE=NONE IO_TYPE=LVCMOS33;
IOBUF PORT "audio_r[2]" PULLMODE=NONE IO_TYPE=LVCMOS33;
IOBUF PORT "audio_r[3]" PULLMODE=NONE IO_TYPE=LVCMOS33;

# SD card
LOCATE COMP "sd_clk" SITE "H2";
LOCATE COMP "sd_cmd" SITE "J1";
LOCATE COMP "sd_d[0]" SITE "J3";
LOCATE COMP "sd_d[1]" SITE "H1";
LOCATE COMP "sd_d[2]" SITE "K1";
LOCATE COMP "sd_d[3]" SITE "K2";
IOBUF PORT "sd_clk" PULLMODE=NONE IO_TYPE=LVCMOS33;
IOBUF PORT "sd_cmd" PULLMODE=NONE IO_TYPE=LVCMOS33;
IOBUF PORT "sd_d[0]" PULLMODE=NONE IO_TYPE=LVCMOS33;
IOBUF PORT "sd_d[1]" PULLMODE=NONE IO_TYPE=LVCMOS33;
IOBUF PORT "sd_d[2]" PULLMODE=NONE IO_TYPE=LVCMOS33;
IOBUF PORT "sd_d[3]" PULLMODE=NONE IO_TYPE=LVCMOS33;
